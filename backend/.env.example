# ── OpenAI ────────────────────────────────────────────────────────────────────
# Used for embeddings (text-embedding-3-small) and chat completions (GPT-4o).
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Qdrant ────────────────────────────────────────────────────────────────────
# Vector database for storing and querying document embeddings.
# Use http://localhost:6333 for local Docker, or your Qdrant Cloud URL.
QDRANT_URL=http://localhost:6333
# Leave empty if running Qdrant locally, fill in if using Qdrant Cloud.
# Get your key at: https://cloud.qdrant.io
QDRANT_API_KEY=
# Name of the collection where your vectors will be stored.
QDRANT_COLLECTION_NAME=rag-knowledge-base

# ── Cohere ────────────────────────────────────────────────────────────────────
# Used for the reranker (rerank-english-v3.0) to improve retrieval precision.
# Get your key at: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Optional. Used if you want to swap GPT-4o for Claude 3.5 Sonnet.
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── LangSmith ─────────────────────────────────────────────────────────────────
# LangChain's tracing and evaluation platform. Enables run inspection and RAGAS evals.
# Sign up for free at: https://smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
